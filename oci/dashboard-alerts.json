{
  "dashboard": {
    "title": "SSTR2026 アラート",
    "tags": ["sstr"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {"from": "now-24h", "to": "now"},
    "panels": [
      {
        "id": 1, "type": "alertlist", "title": "発生中のアラート",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
        "options": {
          "showOptions": "current",
          "maxItems": 20,
          "sortOrder": 1,
          "alertName": "",
          "dashboardAlerts": false,
          "stateFilter": {"firing": true, "pending": true, "noData": true, "normal": false, "error": true},
          "folder": {"title": "SSTR Alerts"},
          "viewMode": "list"
        }
      },
      {
        "id": 2, "type": "alertlist", "title": "アラート履歴（過去24時間）",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 10},
        "options": {
          "showOptions": "changes",
          "maxItems": 50,
          "sortOrder": 1,
          "alertName": "",
          "dashboardAlerts": false,
          "stateFilter": {"firing": true, "pending": true, "noData": true, "normal": true, "error": true},
          "folder": {"title": "SSTR Alerts"},
          "viewMode": "list"
        }
      },
      {
        "id": 3, "type": "timeseries", "title": "サービス稼働率（過去24時間）",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
        "targets": [
          {"expr": "avg_over_time(probe_success[1h])*100", "legendFormat": "{{service}}", "refId": "A"}
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 99, "color": "yellow"}, {"value": 99.9, "color": "green"}]}, "custom": {"fillOpacity": 10}}}
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
